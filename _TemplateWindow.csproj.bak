<Project Sdk="Microsoft.NET.Sdk.WindowsDesktop">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net48</TargetFramework>
    <UseWPF>true</UseWPF>
    <ApplicationIcon>icon.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="icon.ico" />
    <None Remove="Images\start.png" />
    <None Remove="Images\stop.png" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="HtmlAgilityPack" Version="1.11.39" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.1" />
    <PackageReference Include="System.Runtime" Version="4.3.1" />
  </ItemGroup>

  <ItemGroup>
    <Reference Include="Libs">
      <HintPath>..\..\_TemplateCore\Libs\bin\Debug\netcoreapp3.1\Libs.dll</HintPath>
    </Reference>
    <Reference Include="Web">
      <HintPath>..\..\_TemplateCore\Web\bin\Debug\netcoreapp3.1\Web.dll</HintPath>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <Resource Include="icon.ico" />
    <Resource Include="Images\start.png" />
    <Resource Include="Images\stop.png" />
  </ItemGroup>

</Project>